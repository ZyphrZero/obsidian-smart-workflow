{
  "compilerOptions": {
    "inlineSourceMap": true,
    "module": "ESNext",
    "target": "ESNext",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "lib": [
      "DOM",
      "ESNext"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "scripts",
    "binaries",
    "rust-servers",
    "plugin-package"
  ]
}
